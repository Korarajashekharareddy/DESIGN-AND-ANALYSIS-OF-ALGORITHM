#include <iostream>
#include <climits>
using namespace std;

#define V 4  // number of cities

int tsp(int graph[V][V], bool visited[], int currPos, int n, int count, int cost, int &ans) {
    // If all cities visited, return to start
    if (count == n && graph[currPos][0]) {
        ans = min(ans, cost + graph[currPos][0]);
        return ans;
    }

    for (int i = 0; i < n; i++) {
        if (!visited[i] && graph[currPos][i]) {
            visited[i] = true;
            tsp(graph, visited, i, n, count + 1, cost + graph[currPos][i], ans);
            visited[i] = false; // backtrack
        }
    }
    return ans;
}

int main() {
    int graph[V][V] = {
        {0, 10, 15, 20},
        {10, 0, 35, 25},
        {15, 35, 0, 30},
        {20, 25, 30, 0}
    };

    bool visited[V] = {false};
    visited[0] = true;

    int ans = INT_MAX;

    cout << "Minimum travelling cost = "
         << tsp(graph, visited, 0, V, 1, 0, ans);

    return 0;
}
